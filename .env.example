# DeepSeek API settings
DEEPSEEK_API_KEY=key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# MinerU API settings
MINERU_API_KEY=key
MINERU_API_BASE=https://mineru.net

# Quartzy API settings
QUARTZY_API_TOKEN=token
QUARTZY_AUTH0_ACCESS_TOKEN=auth0_jwt_from_graphql_request_header
# QUARTZY_GRAPHQL_JWT is also accepted as an alias for QUARTZY_AUTH0_ACCESS_TOKEN.
QUARTZY_LAB_ID=lab_id # is a uuid, can be found at developer tab of lab settings
QUARTZY_TYPE_ID=b68c4109-7434-4404-899b-4922bac8b489 # General Supply, for all types 
# can visit https://api.quartzy.com/types with token in header
